{
  "name": "sloppify-url-shortener",
  "version": "0.0.0",
  "private": true,
  "description": "Just a URL shortener",
  "license": "ISC",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check": "turbo run lint typecheck && prettier . --check"
  },
  "devDependencies": {
    "prettier": "3.9.5",
    "prettier-plugin-tailwindcss": "0.8.0",
    "turbo": "^2.10.4",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.11.0"
}
